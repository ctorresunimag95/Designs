@page "/browse"
@rendermode InteractiveServer
@inject ServiceBusBrowser Browser
@inject IOptions<EntityCatalogOptions> Catalog

<h1>Browse messages</h1>

<div class="panel">
    <div class="row">
        <div class="field" style="min-width: 260px;">
            <label>Entity</label>
            <select @bind="_selectedEntity" @bind:after="OnEntityChanged">
                <option value="">— choose —</option>
                @foreach (var q in Catalog.Value.Queues)
                {
                    <option value="@QueueKey(q)">queue: @q</option>
                }
                @foreach (var t in Catalog.Value.Topics)
                {
                    @foreach (var s in t.Subscriptions)
                    {
                        <option value="@SubKey(t.Name, s)">topic: @t.Name / @s</option>
                    }
                }
                <option value="@CustomValue">✎ custom…</option>
            </select>
        </div>
        @if (_selectedEntity == CustomValue)
        {
            <div class="field" style="min-width: 200px;">
                <label>Entity name</label>
                <input @bind="_customEntity" placeholder="my.queue.v1" />
            </div>
            <div class="field" style="min-width: 200px;">
                <label>Subscription (topics only)</label>
                <input @bind="_customSubscription" placeholder="leave blank for a queue" />
            </div>
        }
        <div class="field" style="width: 120px;">
            <label>View</label>
            <select @bind="_view">
                <option value="active">Active</option>
                <option value="dead-letter">Dead-letter</option>
            </select>
        </div>
        <div class="field" style="width: 90px;">
            <label>Max</label>
            <input type="number" min="1" max="100" @bind="_max" />
        </div>
        <div class="field">
            <button @onclick="PeekAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(Entity))">
                @(_busy ? "Working…" : "Peek")
            </button>
        </div>
        @if (DeadLetter)
        {
            <div class="field">
                <button class="secondary" @onclick="ResubmitSelectedAsync"
                        disabled="@(_busy || _selectedMessages.Count == 0)">
                    Resubmit selected (@_selectedMessages.Count)
                </button>
            </div>
            <div class="field">
                <button class="secondary" @onclick="ResubmitAllAsync"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(Entity) || _messages is null || _messages.Count == 0)">
                    Resubmit all
                </button>
            </div>
            <div class="field">
                <button class="danger" @onclick="PurgeAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(Entity) || _messages is null || _messages.Count == 0)">
                    Purge DLQ
                </button>
            </div>
        }
    </div>
    <p class="muted">
        Peek is non-destructive. Resubmit re-sends dead-letter messages to the main entity and removes them
        from the DLQ. Purge permanently deletes dead-letter messages. Both act on up to <strong>Max</strong> messages.
    </p>
</div>

@if (_result is not null)
{
    <div class="alert @(_result.Value.ok ? "ok" : "err")">@_result.Value.message</div>
}

@if (_messages is not null)
{
    <div class="panel">
        @if (_messages.Count == 0)
        {
            <p class="muted">No messages found.</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        @if (DeadLetter)
                        {
                            <th style="width: 40px;">
                                <input type="checkbox" @onchange="ToggleSelectAll"
                                       checked="@(_selectedMessages.Count == _messages.Count && _messages.Count > 0)" />
                            </th>
                        }
                        <th>Seq</th>
                        <th>Message Id</th>
                        <th>Subject</th>
                        <th>Enqueued</th>
                        <th>Deliveries</th>
                        @if (DeadLetter)
                        {
                            <th>DLQ reason</th>
                        }
                        <th>Body</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in _messages)
                    {
                        <tr>
                            @if (DeadLetter)
                            {
                                <td style="text-align: center;">
                                    <input type="checkbox"
                                           @onchange="e => ToggleMessage(m.SequenceNumber, e.Value is null ? false : (bool)e.Value)"
                                           checked="@_selectedMessages.Contains(m.SequenceNumber)" />
                                </td>
                            }
                            <td>@m.SequenceNumber</td>
                            <td>@m.MessageId</td>
                            <td>@m.Subject</td>
                            <td>@m.EnqueuedTime.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td>@m.DeliveryCount</td>
                            @if (DeadLetter)
                            {
                                <td>
                                    <div>@m.DeadLetterReason</div>
                                    <div class="muted">@m.DeadLetterErrorDescription</div>
                                </td>
                            }
                            <td>
                                @if (m.Body is not null && m.Body.Length > BodyPreviewLength)
                                {
                                    <pre class="body-preview" @onclick="() => OpenPreview(m.Body)">@m.Body[..BodyPreviewLength]<span class="muted">… (click to expand)</span></pre>
                                }
                                else
                                {
                                    <pre>@m.Body</pre>
                                }
                                @if (m.ApplicationProperties.Count > 0)
                                {
                                    <details>
                                        <summary class="muted">properties (@m.ApplicationProperties.Count)</summary>
                                        <pre>@string.Join("\n", m.ApplicationProperties.Select(p => $"{p.Key} = {p.Value}"))</pre>
                                    </details>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@if (_previewBody is not null)
{
    <div class="modal-overlay" @onclick="ClosePreview">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>Message body</span>
                <button class="secondary" @onclick="ClosePreview">✕</button>
            </div>
            <pre class="modal-body">@_previewBody</pre>
        </div>
    </div>
}

@code {
    private const string CustomValue = "__custom__";
    private const int BodyPreviewLength = 120;

    private string _selectedEntity = "";
    private string _customEntity = "";
    private string _customSubscription = "";
    private string _view = "active";
    private int _max = 20;
    private bool _busy;
    private IReadOnlyList<MessageView>? _messages;
    private (bool ok, string message)? _result;
    private HashSet<long> _selectedMessages = new();
    private string? _previewBody;

    private void OpenPreview(string body) => _previewBody = body;
    private void ClosePreview() => _previewBody = null;

    private bool DeadLetter => _view == "dead-letter";

    private static string QueueKey(string queue) => $"q|{queue}|";
    private static string SubKey(string topic, string sub) => $"s|{topic}|{sub}";

    private string Entity
    {
        get
        {
            if (_selectedEntity == CustomValue) return _customEntity.Trim();
            if (string.IsNullOrEmpty(_selectedEntity)) return "";
            return _selectedEntity.Split('|')[1];
        }
    }

    private string? Subscription
    {
        get
        {
            if (_selectedEntity == CustomValue)
                return string.IsNullOrWhiteSpace(_customSubscription) ? null : _customSubscription.Trim();
            if (string.IsNullOrEmpty(_selectedEntity)) return null;
            var sub = _selectedEntity.Split('|')[2];
            return string.IsNullOrEmpty(sub) ? null : sub;
        }
    }

    private void OnEntityChanged()
    {
        _messages = null;
        _result = null;
        _selectedMessages.Clear();
    }

    private async Task PeekAsync()
    {
        await RunAsync(async () =>
        {
            _messages = await Browser.PeekAsync(Entity, Subscription, DeadLetter, _max);
            _result = (true, $"Peeked {_messages.Count} message(s).");
            _selectedMessages.Clear();
        });
    }

    private void ToggleMessage(long sequenceNumber, bool selected)
    {
        if (selected)
            _selectedMessages.Add(sequenceNumber);
        else
            _selectedMessages.Remove(sequenceNumber);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        _selectedMessages.Clear();
        if (e.Value is bool selected && selected && _messages is not null)
        {
            foreach (var m in _messages)
            {
                _selectedMessages.Add(m.SequenceNumber);
            }
        }
    }

    private async Task ResubmitSelectedAsync()
    {
        await RunAsync(async () =>
        {
            var count = await Browser.ResubmitDeadLetterBySequenceNumbersAsync(Entity, Subscription, _selectedMessages.ToList(),
_max);
            _result = (true, $"Resubmitted {count} selected dead-letter message(s) to '{Entity}'.");
            _selectedMessages.Clear();
            _messages = await Browser.PeekAsync(Entity, Subscription, true, _max);
        });
    }

    private async Task ResubmitAllAsync()
    {
        await RunAsync(async () =>
        {
            var count = await Browser.ResubmitDeadLetterAsync(Entity, Subscription, _max);
            _result = (true, $"Resubmitted {count} dead-letter message(s) to '{Entity}'.");
            _selectedMessages.Clear();
            _messages = await Browser.PeekAsync(Entity, Subscription, true, _max);
        });
    }

    private async Task PurgeAsync()
    {
        await RunAsync(async () =>
        {
            var count = await Browser.PurgeDeadLetterAsync(Entity, Subscription, _max);
            _result = (true, $"Purged {count} dead-letter message(s).");
            _selectedMessages.Clear();
            _messages = await Browser.PeekAsync(Entity, Subscription, true, _max);
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _result = null;
        if (string.IsNullOrWhiteSpace(Entity)) return;

        _busy = true;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _result = (false, $"Operation failed: {ex.Message}");
        }
        finally
        {
            _busy = false;
        }
    }
}
