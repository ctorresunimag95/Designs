{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceBus": {
    "Entities": {
      "Queues": [
        "my.queue.v1",
        "my.queue.v2"
      ],
      "Topics": [
        {
          "Name": "my.topic.v1",
          "Subscriptions": [
            "my-topic-subscription",
            "sample-function-subscription"
          ]
        }
      ]
    }
  }
}
